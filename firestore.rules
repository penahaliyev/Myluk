rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'penahaliyev@gmail.com' && request.auth.token.email_verified == true;
    }
    
    // UserProfile Entity Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'language', 'createdAt', 'updatedAt']) 
          && data.userId == request.auth.uid 
          && data.language is string && data.language.size() <= 2 && (data.language == 'ru' || data.language == 'az' || data.language == 'en')
          && (!('city' in data) || data.city == null || (data.city is string && data.city.size() <= 128))
          && (!('height' in data) || data.height == null || (data.height is number))
          && (!('weight' in data) || data.weight == null || (data.weight is number))
          && (!('tempUnit' in data) || data.tempUnit == null || (data.tempUnit is string && (data.tempUnit == 'C' || data.tempUnit == 'F')))
          && data.createdAt is timestamp 
          && data.updatedAt is timestamp;
    }

    // Prompt Entity Validation
    function isValidPrompt(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'trigger', 'text', 'updatedAt'])
          && data.id is string && data.id.size() <= 64
          && data.title is string && data.title.size() <= 128
          && data.description is string && data.description.size() <= 512
          && data.trigger is string && data.trigger.size() <= 256
          && data.text is string && data.text.size() <= 10000
          && data.updatedAt is timestamp;
    }

    // WardrobeItem Entity Validation
    function isValidWardrobeItem(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'createdAt', 'type'])
          && data.userId == request.auth.uid
          && data.imageUrl is string && data.imageUrl.size() <= 4194304
          && data.type is string && (data.type == 'Item' || data.type == 'Look')
          && (!('category' in data) || (data.category is string && data.category.size() <= 128))
          && (!('color' in data) || (data.color is string && data.color.size() <= 128))
          && (!('source' in data) || (data.source is string && (data.source == 'my' || data.source == 'internet')))
          && (!('tags' in data) || (data.tags is list && data.tags.size() <= 20))
          && (!('rating' in data) || (data.rating is number))
          && (!('advice' in data) || (data.advice is string && data.advice.size() <= 4096))
          && data.createdAt is timestamp;
    }

    // Outfit Entity Validation
    function isValidOutfit(data) {
      return data.keys().hasAll(['userId', 'itemIds', 'createdAt', 'updatedAt'])
          && data.userId == request.auth.uid
          && (!('dayOfWeek' in data) || (data.dayOfWeek is string && data.dayOfWeek.size() <= 128))
          && data.itemIds is list && data.itemIds.size() <= 15 && (data.itemIds.size() == 0 || data.itemIds[0] is string)
          && (!('description' in data) || (data.description is string && data.description.size() <= 2048))
          && (!('aiEvaluation' in data) || (data.aiEvaluation is string && data.aiEvaluation.size() <= 2048))
          && (!('status' in data) || (data.status is string && (data.status == 'READY' || data.status == 'NEEDS_IMPROVEMENT' || data.status == 'MISSING_ITEM' || data.status == 'NOT_RECOMMENDED' || data.status == 'AI_CHOICE')))
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // ShoppingItem Entity Validation
    function isValidShoppingItem(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt'])
          && data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 256
          && (!('reason' in data) || (data.reason is string && data.reason.size() <= 1024))
          && data.createdAt is timestamp;
    }

    match /prompts/{promptId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAdmin() && isValidPrompt(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().keys().hasOnly(['userId', 'language', 'city', 'height', 'weight', 'tempUnit', 'createdAt', 'updatedAt']);

      allow update: if isVerified()
        && isValidId(userId)
        && request.auth.uid == userId
        && existing().userId == request.auth.uid
        && isValidUserProfile(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['language', 'city', 'height', 'weight', 'tempUnit', 'updatedAt']);
      
      allow delete: if false;

      match /wardrobeItems/{itemId} {
        allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(itemId);
        allow list: if isVerified() && isValidId(userId) && request.auth.uid == userId && resource.data.userId == request.auth.uid;

        allow create: if isVerified()
          && isValidId(userId)
          && isValidId(itemId)
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/users/$(userId))
          && isValidWardrobeItem(incoming())
          && incoming().createdAt == request.time
          && incoming().keys().hasOnly(['userId', 'imageUrl', 'createdAt', 'type', 'category', 'color', 'source', 'tags', 'rating', 'advice']);
          
        allow update: if isVerified()
          && isValidId(userId)
          && isValidId(itemId)
          && request.auth.uid == userId
          && existing().userId == request.auth.uid
          && isValidWardrobeItem(incoming())
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['imageUrl', 'type', 'category', 'color', 'source', 'tags', 'rating', 'advice']);
          
        allow delete: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(itemId) && existing().userId == request.auth.uid;
      }

      match /outfits/{outfitId} {
        allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(outfitId);
        allow list: if isVerified() && isValidId(userId) && request.auth.uid == userId && resource.data.userId == request.auth.uid;

        allow create: if isVerified()
          && isValidId(userId)
          && isValidId(outfitId)
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/users/$(userId))
          && isValidOutfit(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time
          && incoming().keys().size() >= 4; // minimum required: userId, itemIds, createdAt, updatedAt
          
        allow update: if isVerified()
          && isValidId(userId)
          && isValidId(outfitId)
          && request.auth.uid == userId
          && existing().userId == request.auth.uid
          && isValidOutfit(incoming())
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          && incoming().diff(existing()).affectedKeys().hasOnly(['dayOfWeek', 'itemIds', 'description', 'aiEvaluation', 'status', 'updatedAt']);
          
        allow delete: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(outfitId) && existing().userId == request.auth.uid;
      }
      match /shoppingItems/{itemId} {
        allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(itemId);
        allow list: if isVerified() && isValidId(userId) && request.auth.uid == userId && resource.data.userId == request.auth.uid;

        allow create: if isVerified()
          && isValidId(userId)
          && isValidId(itemId)
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/users/$(userId))
          && isValidShoppingItem(incoming())
          && incoming().createdAt == request.time
          && incoming().keys().hasOnly(['userId', 'name', 'reason', 'createdAt']);
          
        allow update: if isVerified()
          && isValidId(userId)
          && isValidId(itemId)
          && request.auth.uid == userId
          && existing().userId == request.auth.uid
          && isValidShoppingItem(incoming())
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'reason']);
          
        allow delete: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(itemId) && existing().userId == request.auth.uid;
      }
    }
  }
}
